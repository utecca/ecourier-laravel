{
    "name": "ecourier/ecourier-laravel",
    "description": "Laravel wrapper for the eCourier PHP SDK.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ecourier/ecourier": "dev-main",
        "illuminate/support": "^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.93",
        "spatie/laravel-webhook-client": "^3.6"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Ecourier\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ecourier\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ecourier\\Laravel\\EcourierServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "format": "pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    }
}
